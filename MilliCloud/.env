# =============================================================================
# Milli Cloud Security – local docker-compose environment
# Generated for first-time local boot. Change the secrets before any prod use.
# =============================================================================

# ---- Image versions (use the prebuilt upstream images for now) -------------
PROWLER_API_VERSION=stable
PROWLER_UI_VERSION=stable
PROWLER_MCP_VERSION=stable

# ---- Django / API ---------------------------------------------------------
DJANGO_ALLOWED_HOSTS=localhost,127.0.0.1,prowler-api
DJANGO_BIND_ADDRESS=0.0.0.0
DJANGO_PORT=8080
DJANGO_DEBUG=False
DJANGO_SETTINGS_MODULE=config.django.production
DJANGO_LOGGING_FORMATTER=human_readable
DJANGO_LOGGING_LEVEL=INFO
DJANGO_WORKERS=2
DJANGO_ACCESS_TOKEN_LIFETIME=30
DJANGO_REFRESH_TOKEN_LIFETIME=1440
DJANGO_CACHE_MAX_AGE=3600
DJANGO_STALE_WHILE_REVALIDATE=60
# Leave the JWT keys empty – the API auto-generates an RSA keypair on first
# boot under /home/prowler/.config/prowler-api (mounted at ./_data/api).
DJANGO_TOKEN_SIGNING_KEY=
DJANGO_TOKEN_VERIFYING_KEY=
# Fernet key used to encrypt provider secrets in the DB.
DJANGO_SECRETS_ENCRYPTION_KEY=sFl7KAXBNQfMdJTHpHLbsBJJwRlVTW7gdkVleHRBTBM=
DJANGO_THROTTLE_TOKEN_OBTAIN=50/minute
DJANGO_MANAGE_DB_PARTITIONS=True
DJANGO_CELERY_DEADLOCK_ATTEMPTS=5
DJANGO_BROKER_VISIBILITY_TIMEOUT=86400
DJANGO_SENTRY_DSN=
DJANGO_DELETION_BATCH_SIZE=5000

# ---- PostgreSQL -----------------------------------------------------------
POSTGRES_HOST=postgres-db
POSTGRES_PORT=5432
POSTGRES_ADMIN_USER=prowler
POSTGRES_ADMIN_PASSWORD=S3cret
POSTGRES_USER=prowler_user
POSTGRES_PASSWORD=S3cret
POSTGRES_DB=prowler_db

# ---- Valkey (Redis-compatible) -------------------------------------------
VALKEY_HOST=valkey
VALKEY_PORT=6379
VALKEY_DB=0

# ---- Neo4j (Attack Paths graph DB) ---------------------------------------
NEO4J_HOST=neo4j
NEO4J_PORT=7687
NEO4J_USER=neo4j
NEO4J_PASSWORD=S3cretNeo4jPwd

# ---- Sentry ---------------------------------------------------------------
SENTRY_ENVIRONMENT=local
SENTRY_RELEASE=local

# ---- UI <-> API wiring ----------------------------------------------------
UI_PORT=3000
# Auth.js v5 (NextAuth) — must trust the host or the sign-in callback 500s.
AUTH_TRUST_HOST=true
AUTH_SECRET=Hk9pT2sR8vXyZmNqLwBcDeFgJiKoQuVx
AUTH_URL=http://localhost:3000
NEXTAUTH_SECRET=Hk9pT2sR8vXyZmNqLwBcDeFgJiKoQuVx
NEXTAUTH_URL=http://localhost:3000
API_BASE_URL=http://prowler-api:8080/api/v1
API_BASE_URL_SERVER=http://prowler-api:8080/api/v1
NEXT_PUBLIC_API_BASE_URL=http://localhost:8080/api/v1
SITE_URL=http://localhost:3000

# ---- Social login (leave blank for password login) -----------------------
DJANGO_GOOGLE_OAUTH_CLIENT_ID=
DJANGO_GOOGLE_OAUTH_CLIENT_SECRET=
DJANGO_GOOGLE_OAUTH_CALLBACK_URL=
DJANGO_GITHUB_OAUTH_CLIENT_ID=
DJANGO_GITHUB_OAUTH_CLIENT_SECRET=
DJANGO_GITHUB_OAUTH_CALLBACK_URL=
OPENAI_API_KEY=sk-proj-REPLACE_WITH_YOUR_ACTUAL_KEY
